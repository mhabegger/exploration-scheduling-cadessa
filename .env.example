# Cloudflare resource configuration used while building the Worker.
# Use the real 32-character configuration ID in Workers Builds.
HYPERDRIVE_ID="00000000000000000000000000000000"

# Local Vite/Workers connection override. This connects directly and does not
# emulate Hyperdrive pooling or query caching.
CLOUDFLARE_HYPERDRIVE_LOCAL_CONNECTION_STRING_HYPERDRIVE="postgresql://postgres:postgres@127.0.0.1:5432/cadessa"

# Direct privileged connection used only by drizzle-kit migrations.
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/cadessa"
